{
  "name": "blitz-quick",
  "private": true,
  "scripts": {
    "format": "biome format --write .",
    "check": "bun x tsc --noEmit",
    "gen": "bun run scripts/gen-rust-op.ts",
    "build": "bun run scripts/gen-rust-op.ts && bun run --filter demo build",
    "dev": "bun run --filter demo dev"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14"
  }
}
